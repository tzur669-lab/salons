# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Firebase emulator artifacts (from `npm run test:rules`)
*-debug.log
firebase-debug.log
firestore-debug.log
ui-debug.log
/.firebase/

# env files (can opt-in for committing if needed)
.env*

# Android signing — never commit keystores or base64 exports
*.keystore
*.jks
keystore_b64.txt

# Firebase service account keys — never commit
*-firebase-adminsdk-*.json

# IDE
.idea/
android/.idea/
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local Node toolchain (installed without sudo for the iOS setup — do not commit)
/.toolchain

# stray Firebase plist download (the real one lives in ios/App/App/GoogleService-Info.plist)
/GoogleService-Info.plist.xml

# stray blank Xcode SwiftUI project accidentally created — not part of the app
/roni nail/
