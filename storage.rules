rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Salon-scoped assets — owner can read/write, anyone can read.
    match /salons/{salonId}/{allPaths=**} {
      // Public read (gallery images, home photo, payment QR codes).
      allow read: if true;

      // Only the salon owner may write/delete.
      allow write: if request.auth != null
        && request.auth.uid == firestore.get(
             /databases/(default)/documents/salons/$(salonId)
           ).data.ownerUid
        // Enforce reasonable upload size (10 MB max).
        && request.resource.size <= 10 * 1024 * 1024
        // Allow only images.
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
